# Core data/ML
pandas
numpy
scikit-learn
scipy
matplotlib
seaborn
joblib
ucimlrepo
# In the base (serving) requirements, not just dev, because whichever model
# wins train.py's comparison becomes models/final_model/ — the serving image
# must be able to unpickle it regardless of which algorithm that turns out to be.
xgboost

# Experiment tracking / model packaging client (skinny: no tracking-server/UI deps,
# safe to use identically in the training venv and the serving Docker image)
mlflow-skinny
cloudpickle
# skops is mlflow's default sklearn serialization format (safer than raw pickle —
# no arbitrary code execution on load) and is required at *inference* time too,
# not just training, to deserialize models/final_model/model.skops.
skops

# Serving API
fastapi
uvicorn[standard]
pydantic
prometheus-client
python-multipart
